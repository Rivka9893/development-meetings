{
    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        "outDir": "./dist",
        "module": "nodenext",
        "target": "esnext",
        "lib": [
            "esnext"
        ],
        "types": [
            "node"
        ],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "strict": true,
        "jsx": "react-jsx",
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
    },
    "include": [
        "index.ts",
        "config/**/*.ts",
        "controllers/**/*.ts",
        "middlewares/**/*.ts",
        "routes/**/*.ts",
        "types/**/*.ts",
        "utils/**/*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "frontend",
        "mysql_data"
    ]
}